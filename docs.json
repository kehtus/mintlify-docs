{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "name": "Proportion",
  "description": "Prop firm для prop firms. Капитал, риск-движок и сеттлмент as-a-service на HyperEVM.",
  "colors": {
    "primary": "#109D90",
    "light": "#4FD2C1",
    "dark": "#109D90"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "light",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#0D0D13"
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "contextual": {
    "options": ["copy", "view", "assistant", "mcp", "add-mcp"]
  },
  "navigation": {
    "groups": [
      {
        "group": "Введение",
        "pages": ["index"]
      },
      {
        "group": "Для трейдеров",
        "pages": [
          "traders/index",
          "traders/rules",
          "traders/payouts"
        ]
      },
      {
        "group": "Для билдеров",
        "pages": [
          "builders/index",
          "builders/onboarding",
          "builders/rules",
          "builders/fees"
        ]
      },
      {
        "group": "Vault",
        "pages": ["vault"]
      },
      {
        "group": "SDK",
        "pages": ["sdk"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://trade.proportion.fi"
      }
    ],
    "primary": {
      "type": "github",
      "href": "https://github.com/kehtus/mintlify-docs"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/proportion_fi",
      "github": "https://github.com/kehtus"
    }
  }
}
