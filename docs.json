{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Proportion",
  "description": "Prop-trading infrastructure built on Hyperliquid.",
  "colors": {
    "primary": "#00D4FF",
    "light": "#00D4FF",
    "dark": "#00A3CC"
  },
  "favicon": "/logo/icon_black.png",
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#06080F"
    },
    "decoration": "gradient"
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "contextual": {
    "options": []
  },
  "navigation": {
    "languages": [
      {
        "language": "ru",
        "groups": [
          {
            "group": "Intro",
            "pages": ["index", "offering"]
          },
          {
            "group": "Trade",
            "pages": [
              "traders/index",
              "traders/rules",
              "traders/payouts"
            ]
          },
          {
            "group": "Build",
            "pages": [
              "builders/index",
              "builders/onboarding",
              "builders/rules",
              "builders/fees"
            ]
          },
          {
            "group": "Vault",
            "pages": ["vault/index", "vault/yield"]
          }
        ]
      },
      {
        "language": "en",
        "default": true,
        "groups": [
          {
            "group": "Intro",
            "pages": ["en/index", "en/offering"]
          },
          {
            "group": "Trade",
            "pages": [
              "en/traders/index",
              "en/traders/rules",
              "en/traders/payouts"
            ]
          },
          {
            "group": "Build",
            "pages": [
              "en/builders/index",
              "en/builders/onboarding",
              "en/builders/rules",
              "en/builders/fees"
            ]
          },
          {
            "group": "Vault",
            "pages": ["en/vault/index", "en/vault/yield"]
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/logo2-light.svg",
    "dark": "/logo/logo2.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Security Audit",
        "icon": "shield-check",
        "href": "https://beosin.com/audits/Proportion_202603161420.pdf"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://proportion.fi"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/proportion_fi",
      "telegram": "https://t.me/keysigner"
    }
  }
}
