{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Proportion",
  "description": "Prop firm для prop firms. Капитал, риск-движок и сеттлмент as-a-service на HyperEVM.",
  "colors": {
    "primary": "#00D4FF",
    "light": "#00D4FF",
    "dark": "#00A3CC"
  },
  "favicon": "/favicon.svg",
  "appearance": {
    "default": "dark",
    "strict": false
  },
  "background": {
    "color": {
      "light": "#FFFFFF",
      "dark": "#06080F"
    }
  },
  "fonts": {
    "heading": {
      "family": "Inter",
      "weight": 600
    },
    "body": {
      "family": "Inter",
      "weight": 400
    }
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "contextual": {
    "options": ["copy", "view", "mcp", "add-mcp"]
  },
  "navigation": {
    "groups": [
      {
        "group": "Intro",
        "pages": ["index", "offering"]
      },
      {
        "group": "Trade",
        "pages": [
          "traders/index",
          "traders/rules",
          "traders/payouts"
        ]
      },
      {
        "group": "Build",
        "pages": [
          "builders/index",
          "builders/onboarding",
          "builders/rules",
          "builders/fees"
        ]
      },
      {
        "group": "Vault",
        "pages": ["vault/index", "vault/yield"]
      },
      {
        "group": "SDK",
        "pages": ["sdk"]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "/"
  },
  "navbar": {
    "links": [
      {
        "label": "Audit",
        "href": "https://beosin.com/audits/Proportion_202603161420.pdf"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Open App",
      "href": "https://proportion.fi"
    }
  },
  "footer": {
    "socials": {
      "x": "https://x.com/proportion_fi"
    }
  }
}
